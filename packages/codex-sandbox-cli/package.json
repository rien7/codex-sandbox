{
  "name": "@codex-sandbox/cli",
  "version": "0.3.0",
  "type": "module",
  "description": "CLI for testing the Codex-derived sandbox host",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rien7/codex-sandbox.git",
    "directory": "packages/codex-sandbox-cli"
  },
  "homepage": "https://github.com/rien7/codex-sandbox#readme",
  "bugs": {
    "url": "https://github.com/rien7/codex-sandbox/issues"
  },
  "bin": {
    "codex-sandbox": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "prebuild": "pnpm --dir ../codex-sandbox-adapter build",
    "precheck": "pnpm --dir ../codex-sandbox-adapter build",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && pnpm exec tsc -p tsconfig.json",
    "check": "pnpm exec tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@rien7/codex-sandbox": "workspace:*"
  }
}
