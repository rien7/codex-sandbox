{
  "name": "@rien7/codex-sandbox",
  "version": "0.3.0",
  "type": "module",
  "description": "TypeScript adapter for the Codex-derived sandbox host",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rien7/codex-sandbox.git",
    "directory": "packages/codex-sandbox-adapter"
  },
  "homepage": "https://github.com/rien7/codex-sandbox#readme",
  "bugs": {
    "url": "https://github.com/rien7/codex-sandbox/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "native",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "dependencies": {
    "env-paths": "^3.0.0"
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && pnpm exec tsc -p tsconfig.json",
    "check": "pnpm exec tsc -p tsconfig.json --noEmit"
  }
}
