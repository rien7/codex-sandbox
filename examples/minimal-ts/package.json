{
  "name": "codex-sandbox-example-minimal",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "pnpm --dir ../../packages/codex-sandbox-adapter build",
    "precheck": "pnpm --dir ../../packages/codex-sandbox-adapter build",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && pnpm exec tsc -p tsconfig.json",
    "check": "pnpm exec tsc -p tsconfig.json --noEmit",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@rien7/codex-sandbox": "workspace:*"
  }
}
